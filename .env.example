# ── LLM Configuration ─────────────────────────────────────────────────────────
# The app uses an OpenAI-compatible API.  Point BASE_URL to any provider:
#   • OpenAI:  https://api.openai.com/v1
#   • Ollama:  http://localhost:11434/v1
#   • LM Studio: http://localhost:1234/v1
#   • Together / Groq / etc.

OPENAI_API_KEY="ollama"
OPENAI_BASE_URL=:"http://localhost:11434/v"
LLM_MODEL="gemma4:12b"

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
